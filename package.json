{
  "name": "ccmux",
  "version": "1.2.0-rc.1",
  "private": true,
  "description": "Track all your AI coding agents (Claude Code, Codex, Cursor, ...) in tmux and jump to the one that needs you",
  "license": "MIT",
  "author": "epilande",
  "repository": {
    "type": "git",
    "url": "https://github.com/epilande/ccmux.git"
  },
  "homepage": "https://github.com/epilande/ccmux",
  "bugs": {
    "url": "https://github.com/epilande/ccmux/issues"
  },
  "keywords": [
    "claude",
    "claude-code",
    "codex",
    "opencode",
    "gemini",
    "ai-agents",
    "tmux",
    "session-manager",
    "tui",
    "cli",
    "terminal"
  ],
  "type": "module",
  "main": "src/index.ts",
  "files": [
    "bin",
    "src",
    "bunfig.toml",
    "tsconfig.json"
  ],
  "bin": {
    "ccmux": "./bin/ccmux"
  },
  "scripts": {
    "start": "bun src/index.ts",
    "dev": "bun --watch src/index.ts",
    "build": "bun run build.ts",
    "test": "bun test",
    "typecheck": "tsc --noEmit",
    "knip": "knip",
    "check:unused": "bun run knip"
  },
  "dependencies": {
    "@opentui/core": "0.1.97",
    "@opentui/solid": "0.1.97",
    "anser": "^2.3.5",
    "chokidar": "^4.0.0",
    "commander": "^14.0.0",
    "dbus-next": "^0.10.2",
    "fuzzysort": "^3.0.0",
    "solid-js": "^1.9.0"
  },
  "devDependencies": {
    "@types/bun": "1.3.6",
    "knip": "^6.14.2",
    "prettier": "3.8.1",
    "typescript": "^5.0.0"
  }
}
